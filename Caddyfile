# Domain from DOMAIN env var. Falls back to "localhost" if unset.
# Caddy handles TLS automatically: Let's Encrypt for real domains,
# self-signed for localhost.
# Custom certs: upload via admin panel → creates /etc/caddy/certs/custom.caddy
{$DOMAIN:localhost} {
  # Import custom cert snippet if any files exist (uploaded via admin panel)
  import /etc/caddy/certs/*.caddy

  # File downloads + uploads — always go to API (users share direct /file/* links)
  handle /file/* {
    reverse_proxy api:3000
  }
  handle /upload* {
    reverse_proxy api:3000
  }
  handle /sharex/* {
    reverse_proxy api:3000
  }
  handle /health* {
    reverse_proxy api:3000
  }

  # API routes — only for fetch() calls (JSON), not browser page loads
  @apiCall {
    header Accept application/json
  }
  handle @apiCall {
    reverse_proxy api:3000
  }

  # Everything else → Next.js frontend (browser gets proper HTML pages)
  reverse_proxy web:3000
}
