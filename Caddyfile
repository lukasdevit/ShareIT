{$DOMAIN:localhost}, goletz.dev {
  handle /file/* {
    reverse_proxy api:3000
  }

  # GET /files with query params → API (file listing)
  @filesApi {
    method GET
    path /files
    query page=*
  }
  handle @filesApi {
    reverse_proxy api:3000
  }

  # POST /files → API (file listing with body, if any)
  @filesApiPost {
    method POST
    path /files
  }
  handle @filesApiPost {
    reverse_proxy api:3000
  }

  handle /upload* {
    reverse_proxy api:3000
  }
  handle /auth/* {
    reverse_proxy api:3000
  }
  handle /sharex/* {
    reverse_proxy api:3000
  }
  handle /admin/* {
    reverse_proxy api:3000
  }
  handle /health* {
    reverse_proxy api:3000
  }
  reverse_proxy web:3000
}
