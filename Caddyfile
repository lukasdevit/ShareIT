# Domain from DOMAIN env var. Falls back to "localhost" if unset.
# Caddy handles TLS automatically: Let's Encrypt for real domains,
# self-signed for localhost.
{$DOMAIN:localhost} {
  handle /file/* {
    reverse_proxy api:3000
  }

  @filesApi {
    method GET
    path /files
    query page=*
  }
  handle @filesApi {
    reverse_proxy api:3000
  }

  @filesApiPost {
    method POST
    path /files
  }
  handle @filesApiPost {
    reverse_proxy api:3000
  }

  handle /upload* {
    reverse_proxy api:3000
  }
  handle /auth/* {
    reverse_proxy api:3000
  }
  handle /sharex/* {
    reverse_proxy api:3000
  }
  handle /admin/* {
    reverse_proxy api:3000
  }
  handle /health* {
    reverse_proxy api:3000
  }
  reverse_proxy web:3000
}
