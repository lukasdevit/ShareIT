{
  "name": "shareit",
  "type": "module",
  "version": "1.0.0",
  "description": "Custom file viewer and uploader.",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:admin": "vitest run src/tests/admin",
    "test:integration": "vitest run src/tests/integration",
    "test:coverage": "vitest run --coverage",
    "release": "semantic-release",
    "dev": "B2_ENABLED=false tsx watch --env-file=.env src/server.ts",
    "dev:all": "B2_ENABLED=false concurrently -n api,web -c blue,green \"npm run dev\" \"cd frontend && npm run dev\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lukasdevit/ShareIT.git"
  },
  "keywords": [
    "sharex"
  ],
  "author": "kukasz",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/lib-storage": "^3.1053.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "bcrypt": "^6.0.0",
    "clamscan": "^2.4.0",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.11",
    "pino-pretty": "^13.1.3",
    "sqlite3": "^6.0.1",
    "tsx": "^4.22.3"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/bcrypt": "^6.0.0",
    "@types/clamscan": "^2.4.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/sqlite3": "^5.1.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "semantic-release": "^25.0.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
