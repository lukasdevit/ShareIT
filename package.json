{
  "name": "shareit",
  "type": "module",
  "version": "2.0.1",
  "description": "Self-hosted file sharing app — upload, share, manage.",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:frontend": "cd frontend && npm run test",
    "test:coverage": "vitest run --coverage",
    "dev": "tsx watch --env-file=.env backend/server.ts",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run dev\" \"cd frontend && npm run dev\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lukasdevit/ShareIT.git"
  },
  "keywords": [
    "sharex"
  ],
  "author": "kukasz",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/lib-storage": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@uppy/aws-s3": "^5.1.0",
    "bcrypt": "^6.0.0",
    "clamscan": "^2.4.0",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.11",
    "pino-pretty": "^13.1.3",
    "sqlite3": "^6.0.1",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/clamscan": "^2.4.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/sqlite3": "^5.1.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^10.0.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
