# ── Server ──
PORT=3000
BASE_URL=http://localhost:3000
UPLOAD_DIR=uploads
LOG_PRETTY=true

# ── Security (change these!) ──
JWT_SECRET=change-me-in-production

# ── Default admin user (created on first start if no admin exists) ──
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123
# - termina > openssl rand -hex 32, then copy the secret and put it here :)

# ── Storage: Backblaze B2 (S3-compatible) ──
# Leave B2_ENABLED=false to use local filesystem
# B2_ENABLED=true
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_REGION=us-west-004
# B2_KEY_ID=your-backblaze-key-id
# B2_APP_KEY=your-backblaze-application-key
# B2_BUCKET=your-bucket-name
# B2_PREFIX_SHAREX=my/custom/path/uploads

# ── Optional ──
# DB_PATH=./database.db
# RATE_LIMIT_MAX=1000
# RATE_LIMIT_WINDOW_MS=60000
# ALLOWED_MIME_TYPES=image/png,image/jpeg,text/plain,...
