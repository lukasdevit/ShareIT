# ═══════════════════════════════════════════
#  ShareIT — Environment Configuration
#  Copy this to .env and fill in your values
# ═══════════════════════════════════════════

# ── Required ──
JWT_SECRET=                           # openssl rand -hex 32

# ── Server (optional) ──
# PORT=3000
# BASE_URL=http://localhost:3000
# LOG_PRETTY=true                     # colorful logs in dev, remove for prod

# ── Admin seed (required) ──
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Database (optional, default: ./database.db) ──
# DB_PATH=./database.db

# ── Storage backend (set via Admin Panel → Storage, env vars are fallbacks) ──
# B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
# B2_REGION=us-west-004
# B2_KEY_ID=your-key-id
# B2_APP_KEY=your-app-key
# B2_BUCKET=your-bucket
# B2_PREFIX=shareit/storage/

# ── Domain (required for production HTTPS via Caddy) ──
DOMAIN=localhost


# ── CORS (optional, set to your frontend URL to lock down) ──
# CORS_ORIGIN=https://yourdomain.com
